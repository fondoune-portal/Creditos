# Email Service (si usas alguno)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_app

# Environments
FRONTEND_URL=http://localhost:8080
